---
/**
 * Modular B&B Settings Page
 * Clean, organized structure using components
 */
import SettingsLayout from './SettingsLayout.astro';
import BedrijfsinfoSettings from './BedrijfsinfoSettings.astro';
import AccommodatieSettings from './AccommodatieSettings.astro';
import NotificationSystem from './components/NotificationSystem.astro';
import AccommodatieModal from './components/AccommodatieModal.astro';
---

<div class="grid grid-cols-1 px-4 pt-6 xl:grid-cols-4 xl:gap-4 dark:bg-gray-900">
	<!-- Breadcrumb -->
	<div class="mb-4 col-span-full xl:mb-2">
		<nav class="flex mb-5" aria-label="Breadcrumb">
			<ol class="inline-flex items-center space-x-1 text-sm font-medium md:space-x-2">
				<li class="inline-flex items-center">
					<a href="/" class="inline-flex items-center text-gray-700 hover:text-primary-600 dark:text-gray-300 dark:hover:text-white">
						<svg class="w-5 h-5 mr-2.5" fill="currentColor" viewBox="0 0 20 20">
							<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
						</svg>
						Dashboard
					</a>
				</li>
				<li>
					<div class="flex items-center">
						<svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
						</svg>
						<span class="ml-1 text-gray-400 md:ml-2 dark:text-gray-500" aria-current="page">Instellingen</span>
					</div>
				</li>
			</ol>
		</nav>
		<h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">
			B&B Instellingen
		</h1>
	</div>

	<!-- Sidebar Navigation -->
	<div class="col-span-1">
		<div class="p-4 mb-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 dark:bg-gray-800">
			<nav class="space-y-2">
				<button onclick="showTab('bedrijfsinfo')" id="tab-bedrijfsinfo" class="settings-tab-btn w-full flex items-center px-3 py-2 text-sm font-medium text-left rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 bg-primary-100 text-primary-700 dark:bg-primary-900 dark:text-primary-300">
					<svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4z" clip-rule="evenodd"/>
					</svg>
					Bedrijfsinfo
				</button>
				
				<button onclick="showTab('accommodatie')" id="tab-accommodatie" class="settings-tab-btn w-full flex items-center px-3 py-2 text-sm font-medium text-left rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
					<svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
						<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
					</svg>
					Accommodatie
				</button>
			</nav>
		</div>
	</div>

	<!-- Content Area -->
	<div class="col-span-3">
		<!-- Include Settings Components -->
		<BedrijfsinfoSettings />
		<AccommodatieSettings />
	</div>
</div>

<!-- Include Modals and Notifications -->
<NotificationSystem />
<AccommodatieModal />

<script>
	// Initialize settings when DOM is loaded
	document.addEventListener('DOMContentLoaded', async () => {
		try {
			// Import and initialize core settings functionality
			const coreModule = await import('./js/settingsCore.js');
			await coreModule.initSettings();
			
			// Import and initialize accommodatie handler
			const accommodatieModule = await import('./js/accommodatieHandler.js');
			await accommodatieModule.initAccommodatie();
			
			// Import and initialize bedrijfsinfo handler
			const bedrijfsinfoModule = await import('./js/bedrijfsinfoHandler.js');
			await bedrijfsinfoModule.initBedrijfsinfo();
			
			console.log('All settings modules loaded successfully');
		} catch (error) {
			console.error('Failed to load settings modules:', error);
		}
	});
</script>
