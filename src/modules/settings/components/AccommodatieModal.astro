---
/**
 * Accommodatie Modal Component
 * Modern tab-based modal for managing accommodations
 */
---

<!-- Accommodatie Modal -->
<div id="accommodatie-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
	<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
		<div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" onclick="closeAccommodatieModal()"></div>
		
		<div class="inline-block w-full max-w-5xl p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg dark:bg-gray-800">
			<!-- Modal Header -->
			<div class="flex items-center justify-between mb-6">
				<h3 class="text-xl font-semibold text-gray-900 dark:text-white" id="modal-title">Accommodatie Beheer</h3>
				<button onclick="closeAccommodatieModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			
			<!-- Tab Navigation -->
			<div class="border-b border-gray-200 dark:border-gray-700 mb-6">
				<ul class="flex flex-wrap -mb-px text-sm font-medium text-center text-gray-500 dark:text-gray-400">
					<li class="mr-2">
						<button class="inline-flex items-center p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button active" data-tab="algemeen" onclick="switchAccommodatieTab('algemeen')">
							<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4z" clip-rule="evenodd"/>
							</svg>
							Algemeen
						</button>
					</li>
					<li class="mr-2">
						<button class="inline-flex items-center p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" data-tab="fotos" onclick="switchAccommodatieTab('fotos')">
							<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
							</svg>
							Foto's
						</button>
					</li>
					<li class="mr-2">
						<button class="inline-flex items-center p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" data-tab="tarieven" onclick="switchAccommodatieTab('tarieven')">
							<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
								<path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
							</svg>
							Tarieven
						</button>
					</li>
					<li class="mr-2" id="delete-tab-li" style="display: none;">
						<button class="inline-flex items-center p-4 border-b-2 border-transparent rounded-t-lg hover:text-red-600 hover:border-red-300 dark:hover:text-red-300 tab-button text-red-500" data-tab="verwijderen" onclick="switchAccommodatieTab('verwijderen')">
							<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" clip-rule="evenodd"/>
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8 7a1 1 0 012 0v4a1 1 0 11-2 0V7zM12 7a1 1 0 10-2 0v4a1 1 0 102 0V7z" clip-rule="evenodd"/>
							</svg>
							Verwijderen
						</button>
					</li>
				</ul>
			</div>
			
			<!-- Tab Content -->
			<div class="mt-6">
				<!-- Algemeen Tab -->
				<div id="algemeen-tab" class="tab-content">
					<form class="space-y-6" id="accommodatie-form">
						<!-- Basis Informatie -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="acc-naam" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Accommodatie Naam *</label>
								<input type="text" id="acc-naam" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Basis Kampeerplaats" required>
							</div>
							<div>
								<label for="acc-type" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Type *</label>
								<select id="acc-type" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" required>
									<option value="">Selecteer type...</option>
									<option value="kampeerplaats">Kampeerplaats</option>
									<option value="bnb-kamer">B&B Kamer</option>
									<option value="chalet">Chalet</option>
									<option value="stacaravan">Stacaravan</option>
									<option value="glamping">Glamping</option>
								</select>
							</div>
							<div>
								<label for="acc-max-gasten" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Max. Gasten *</label>
								<input type="number" id="acc-max-gasten" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="7" min="1" required>
							</div>
							<div>
								<label for="acc-oppervlakte" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Oppervlakte (m²)</label>
								<input type="number" id="acc-oppervlakte" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="150">
							</div>
							<div>
								<label for="acc-status" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Status</label>
								<select id="acc-status" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
									<option value="actief">Actief</option>
									<option value="inactief">Inactief</option>
									<option value="onderhoud">Onderhoud</option>
								</select>
							</div>
						</div>
						
						<!-- Beschrijving -->
						<div>
							<label for="acc-beschrijving" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Beschrijving *</label>
							<textarea id="acc-beschrijving" rows="4" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Ruime kampeerplaats van 150 m² met 10 ampère stroom, water- en rioolaansluiting..." required></textarea>
						</div>
						
						<!-- Voorzieningen -->
						<div>
							<label class="block mb-3 text-sm font-medium text-gray-900 dark:text-white">Voorzieningen</label>
							<div class="grid grid-cols-2 md:grid-cols-3 gap-3" id="amenities-grid">
								<!-- Amenities checkboxes will be loaded here -->
							</div>
						</div>
						
						<!-- Extra Informatie -->
						<div>
							<label for="acc-extra-info" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Extra Informatie</label>
							<textarea id="acc-extra-info" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Heb je vragen? Zoek dan gerust contact met ons..."></textarea>
						</div>
					</form>
				</div>
				
				<!-- Foto's Tab -->
				<div id="fotos-tab" class="tab-content hidden">
					<div class="space-y-6">
						<div class="bg-blue-50 border border-blue-200 rounded-lg p-4 dark:bg-blue-900/20 dark:border-blue-800">
							<h4 class="text-lg font-semibold text-blue-900 dark:text-blue-100 mb-3">Foto Beheer</h4>
							<p class="text-blue-700 dark:text-blue-300 mb-4">Upload en beheer foto's voor deze accommodatie. Sleep bestanden hierheen of klik om te selecteren.</p>
						</div>
						
						<!-- Image Upload Area -->
						<div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center dark:border-gray-600">
							<svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
								<path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<div class="mt-4">
								<label for="image-upload" class="cursor-pointer">
									<span class="mt-2 block text-sm font-medium text-gray-900 dark:text-white">Upload foto's</span>
									<input id="image-upload" name="image-upload" type="file" class="sr-only" multiple accept="image/*">
								</label>
								<p class="mt-1 text-xs text-gray-500">PNG, JPG, GIF tot 5MB</p>
							</div>
						</div>
						
						<!-- Current Images Grid -->
						<div id="current-images-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
							<!-- Images will be loaded here -->
						</div>
					</div>
				</div>
				
				<!-- Tarieven Tab -->
				<div id="tarieven-tab" class="tab-content hidden">
					<div class="space-y-6">
						<div class="bg-green-50 border border-green-200 rounded-lg p-4 dark:bg-green-900/20 dark:border-green-800">
							<h4 class="text-lg font-semibold text-green-900 dark:text-green-100 mb-3">Prijzen & Opties</h4>
							<p class="text-green-700 dark:text-green-300">Stel de basisprijzen en seizoensprijzen in voor deze accommodatie.</p>
						</div>
						
						<!-- Basis Prijzen -->
						<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
							<div>
								<label for="acc-prijs" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Basisprijs per nacht (€) *</label>
								<input type="number" step="0.01" id="acc-prijs" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="35.00" required>
							</div>
							<div>
								<label for="acc-weekend-toeslag" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Weekend toeslag (€)</label>
								<input type="number" step="0.01" id="acc-weekend-toeslag" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="5.00">
							</div>
							<div>
								<label for="acc-schoonmaakkosten" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Schoonmaakkosten (€)</label>
								<input type="number" step="0.01" id="acc-schoonmaakkosten" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="25.00">
							</div>
						</div>
						
						<!-- Seizoensprijzen -->
						<div>
							<h5 class="text-md font-medium text-gray-900 dark:text-white mb-4">Seizoensprijzen</h5>
							<div class="space-y-4">
								<div class="grid grid-cols-1 md:grid-cols-4 gap-4 p-4 border border-gray-200 rounded-lg dark:border-gray-600">
									<div>
										<label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Seizoen</label>
										<select class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
											<option value="laag">Laagseizoen</option>
											<option value="midden">Middenseizoen</option>
											<option value="hoog">Hoogseizoen</option>
										</select>
									</div>
									<div>
										<label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Van datum</label>
										<input type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
									</div>
									<div>
										<label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Tot datum</label>
										<input type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
									</div>
									<div>
										<label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Prijs (€)</label>
										<input type="number" step="0.01" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="45.00">
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				
				<!-- Verwijderen Tab -->
				<div id="verwijderen-tab" class="tab-content hidden">
					<div class="space-y-6">
						<div class="bg-red-50 border border-red-200 rounded-lg p-6 dark:bg-red-900/20 dark:border-red-800">
							<div class="flex items-start">
								<div class="flex-shrink-0">
									<svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
									</svg>
								</div>
								<div class="ml-3">
									<h3 class="text-lg font-medium text-red-800 dark:text-red-200">Accommodatie Verwijderen</h3>
									<div class="mt-2 text-sm text-red-700 dark:text-red-300">
										<p>Let op: Deze actie kan niet ongedaan worden gemaakt. Alle gegevens van deze accommodatie worden permanent verwijderd, inclusief:</p>
										<ul class="list-disc list-inside mt-2 space-y-1">
											<li>Alle foto's en bestanden</li>
											<li>Reserveringsgeschiedenis</li>
											<li>Prijsinstellingen</li>
											<li>Reviews en beoordelingen</li>
										</ul>
									</div>
									<div class="mt-4">
										<div class="flex">
											<button type="button" onclick="confirmDeleteAccommodatie()" class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 focus:ring-4 focus:ring-red-300 text-sm font-medium">
												Definitief Verwijderen
											</button>
											<button type="button" onclick="switchAccommodatieTab('algemeen')" class="ml-3 bg-gray-200 text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-300 focus:ring-4 focus:ring-gray-200 text-sm font-medium dark:bg-gray-600 dark:text-gray-200 dark:hover:bg-gray-700">
												Annuleren
											</button>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			
			<!-- Modal Footer -->
			<div class="flex justify-end gap-3 pt-6 mt-6 border-t border-gray-200 dark:border-gray-600">
				<button type="button" onclick="closeAccommodatieModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:ring-4 focus:ring-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700 dark:focus:ring-gray-700">
					Sluiten
				</button>
				<button type="button" onclick="saveAccommodatie()" id="save-button" class="px-4 py-2 text-sm font-medium text-white bg-primary-700 rounded-lg hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
					Opslaan
				</button>
			</div>
		</div>
	</div>
</div>
