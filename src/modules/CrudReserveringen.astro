<script>
	// Modal functions
	function openNieuweReserveringModal() {
		const modal = document.getElementById('reservering-details-modal');
		modal.classList.remove('hidden');
		modal.setAttribute('aria-hidden', 'false');
		
		// Set current ID to null for new reservering FIRST
		window.currentReserveringId = null;
		
		// Clear form for new reservering
		clearReserveringForm();
		
		// Load accommodaties for the dropdown
		loadAccommodatiesForSelector();
		
		// Load gasten for the selector
		loadGastenForSelector();
		
		// For new reserveringen: Show simplified gast selector (no search active, no confirm/cancel buttons)
		document.getElementById('current-gast-info').classList.add('hidden');
		document.getElementById('gast-selector').classList.remove('hidden');
		
		// Hide search results and confirm/cancel buttons initially
		const searchResults = document.getElementById('gast-search-results');
		const confirmBtn = document.getElementById('confirm-gast-btn');
		const cancelBtn = document.getElementById('cancel-gast-btn');
		
		if (searchResults) searchResults.classList.add('hidden');
		if (confirmBtn) confirmBtn.classList.add('hidden');
		if (cancelBtn) cancelBtn.classList.add('hidden');
		
		// Clear search input and make it inactive
		const searchInput = document.getElementById('gast-search-input');
		if (searchInput) {
			searchInput.value = '';
			searchInput.placeholder = 'Klik hier om te zoeken naar bestaande gast...';
			searchInput.readOnly = true;
			searchInput.removeAttribute('oninput');
		}
		
		// Hide "Andere gast" button for new reserveringen
		const andereGastBtn = document.querySelector('button[onclick*="toggleGastSelector"]');
		if (andereGastBtn) {
			andereGastBtn.classList.add('hidden');
		}
		
		// Reset state
		selectedGastData = null;
		
		// Focus management - avoid focusing on search input to prevent activation
		const firstFocusable = modal.querySelector('button:not([onclick*="activateGastSearch"]), select, textarea');
		if (firstFocusable) {
			firstFocusable.focus();
		}
	}
	
	function openReserveringModal(reserveringId) {
		const modal = document.getElementById('reservering-details-modal');
		modal.classList.remove('hidden');
		modal.setAttribute('aria-hidden', 'false');
		
		// Focus management
		const firstFocusable = modal.querySelector('button, input, select, textarea');
		if (firstFocusable) {
			firstFocusable.focus();
		}
		
		// Load accommodaties for the dropdown
		loadAccommodatiesForSelector();
		
		// Load reservering data
		populateModalWithData(reserveringId);
	}
	
	function closeReserveringModal() {
		const modal = document.getElementById('reservering-details-modal');
		
		// Remove focus from any focused element inside modal
		const focusedElement = modal.querySelector(':focus');
		if (focusedElement) {
			focusedElement.blur();
		}
		
		modal.classList.add('hidden');
		modal.setAttribute('aria-hidden', 'true');
	}
	
	function switchTab(tabName) {
		// Hide all tabs
		document.querySelectorAll('.tab-content').forEach(tab => {
			tab.classList.add('hidden');
		});
		
		// Remove active class from all buttons
		document.querySelectorAll('.tab-button').forEach(button => {
			button.classList.remove('active', 'border-primary-600', 'text-primary-600');
			button.classList.add('border-transparent');
		});
		
		// Show selected tab
		document.getElementById(tabName + '-tab').classList.remove('hidden');
		
		// Add active class to selected button
		const activeButton = document.querySelector(`[data-tab="${tabName}"]`);
		activeButton.classList.add('active', 'border-primary-600', 'text-primary-600');
		activeButton.classList.remove('border-transparent');
	}
	
	async function populateModalWithData(reserveringId) {
		// Skip loading data for new reserveringen
		if (!reserveringId) {
			console.log('No reservering ID provided - this is a new reservering');
			return;
		}
		
		try {
			console.log('Loading reservering data for ID:', reserveringId);
			
			const response = await fetch(`/api/reserveringen?id=${reserveringId}`);
			if (!response.ok) {
				throw new Error('Failed to fetch reservering data');
			}
			
			const data = await response.json();
			
			// Populate form fields
			document.getElementById('modal-gast-id').value = data.gast_id || '';
			document.getElementById('modal-gast-naam').value = data.gast_naam || '';
			document.getElementById('modal-gast-email').value = data.gast_email || '';
			document.getElementById('modal-gast-telefoon').value = data.gast_telefoon || '';
			
			// Load gasten for selector
			loadGastenForSelector();
			
			// Convert dates back to YYYY-MM-DD format for date inputs
			document.getElementById('modal-check-in').value = convertDisplayDateToInput(data.check_in) || '';
			document.getElementById('modal-check-out').value = convertDisplayDateToInput(data.check_out) || '';
			
			// Set kamer value after accommodaties are loaded
			setTimeout(() => {
				document.getElementById('modal-kamer').value = data.kamer || '';
			}, 100);
			document.getElementById('modal-aantal-gasten').value = data.aantal_gasten || '';
			
			// Remove currency symbols and convert to proper decimal format for number inputs
			document.getElementById('modal-prijs-per-nacht').value = convertCurrencyToNumber(data.prijs_per_nacht) || '';
			document.getElementById('modal-totaal-prijs').value = convertCurrencyToNumber(data.totaal_prijs) || '';
			document.getElementById('modal-status').value = data.status || 'confirmed';
			document.getElementById('modal-betaalstatus').value = data.betaalstatus || 'pending';
			document.getElementById('modal-aanbetaling').value = convertCurrencyToNumber(data.aanbetaling) || '';
			document.getElementById('modal-restbetaling').value = convertCurrencyToNumber(data.restbetaling) || '';
			document.getElementById('modal-korting').value = convertCurrencyToNumber(data.korting) || '';
			document.getElementById('modal-borg').value = convertCurrencyToNumber(data.borg) || '';
			
			// Set checkboxes
			document.getElementById('ontbijt').checked = data.ontbijt || false;
			document.getElementById('linnen').checked = data.linnen || false;
			document.getElementById('handdoeken').checked = data.handdoeken || false;
			document.getElementById('parkeren').checked = data.parkeren || false;
			
			// Set textarea values
			const publicTextarea = document.querySelector('#opmerkingen-tab textarea:first-of-type');
			const internTextarea = document.querySelector('#opmerkingen-tab textarea:last-of-type');
			if (publicTextarea) publicTextarea.value = data.opmerkingen_publiek || '';
			if (internTextarea) internTextarea.value = data.opmerkingen_intern || '';
			
			// Set korting and borg
			const kortingInput = document.querySelector('input[placeholder="€0,00"]');
			const borgInput = document.querySelector('input[placeholder="€50,00"]');
			if (kortingInput) kortingInput.value = data.korting || '€0,00';
			if (borgInput) borgInput.value = data.borg || '€50,00';
			
			// Store current reservering ID for saving
			window.currentReserveringId = reserveringId;
			
		} catch (error) {
			console.error('Error loading reservering data:', error);
			showNotification('Fout bij het laden van reservering gegevens', 'error');
		}
	}
	
	// Add event listeners for reservering rows
	document.addEventListener('DOMContentLoaded', function() {
		// Add click handlers to all reservering rows
		document.querySelectorAll('.reservering-row').forEach(row => {
			row.addEventListener('click', function(e) {
				// Don't trigger if clicking on checkbox
				if (e.target.type === 'checkbox') return;
				
				const reserveringId = this.getAttribute('data-reservering-id');
				if (reserveringId) {
					openReserveringModal(reserveringId);
				}
			});
		});
	});

	// Close modal when clicking outside
	document.addEventListener('click', function(event) {
		const modal = document.getElementById('reservering-details-modal');
		if (event.target === modal) {
			closeReserveringModal();
		}
	});
	
	function convertDateFormat(dateString) {
		// Convert "2024-01-15" to "2024-01-15" format (for API)
		if (!dateString) return '';
		return dateString; // Date inputs already give us YYYY-MM-DD format
	}
	
	function convertDisplayDateToInput(dateString) {
		// Convert "15 Jan 2024" to "2024-01-15" format for date inputs
		if (!dateString) return '';
		
		const months = {
			'Jan': '01', 'Feb': '02', 'Mar': '03', 'Apr': '04',
			'May': '05', 'Jun': '06', 'Jul': '07', 'Aug': '08',
			'Sep': '09', 'Oct': '10', 'Nov': '11', 'Dec': '12'
		};
		
		const parts = dateString.split(' ');
		if (parts.length === 3) {
			const day = parts[0].padStart(2, '0');
			const month = months[parts[1]];
			const year = parts[2];
			return `${year}-${month}-${day}`;
		}
		
		return dateString; // Return as-is if format doesn't match
	}
	
	function convertCurrencyToNumber(currencyString) {
		// Convert "€125,00" to "125.00" for number inputs
		if (!currencyString) return '';
		
		// Remove € symbol and convert comma to dot
		return currencyString.toString()
			.replace(/€/g, '')
			.replace(/\./g, '') // Remove thousand separators
			.replace(/,/g, '.') // Convert decimal comma to dot
			.trim();
	}
	
	function showNotification(message, type = 'success') {
		const successNotification = document.getElementById('success-notification');
		const errorNotification = document.getElementById('error-notification');
		
		// Hide both notifications first
		successNotification.classList.add('hidden');
		errorNotification.classList.add('hidden');
		
		if (type === 'success') {
			document.getElementById('notification-message').textContent = message;
			successNotification.classList.remove('hidden');
			
			// Auto hide after 3 seconds
			setTimeout(() => {
				successNotification.classList.add('hidden');
			}, 3000);
		} else {
			document.getElementById('error-message').textContent = message;
			errorNotification.classList.remove('hidden');
			
			// Auto hide after 5 seconds
			setTimeout(() => {
				errorNotification.classList.add('hidden');
			}, 5000);
		}
	}
	
	// Gast selector functions
	let allGasten = [];
	let selectedGastData = null;
	
	function clearReserveringForm() {
		// Clear all form fields for new reservering
		document.getElementById('modal-gast-id').value = '';
		document.getElementById('modal-gast-naam').value = '';
		document.getElementById('modal-gast-email').value = '';
		document.getElementById('modal-gast-telefoon').value = '';
		document.getElementById('modal-check-in').value = '';
		document.getElementById('modal-check-out').value = '';
		document.getElementById('modal-kamer').value = '';
		document.getElementById('modal-aantal-gasten').value = '1';
		document.getElementById('modal-prijs-per-nacht').value = '';
		document.getElementById('modal-totaal-prijs').value = '';
		document.getElementById('modal-status').value = 'confirmed'; // Default status
		document.getElementById('modal-betaalstatus').value = 'pending'; // Default payment status
		document.getElementById('modal-korting').value = '0';
		document.getElementById('modal-borg').value = '50';
		document.getElementById('modal-aanbetaling').value = '';
		document.getElementById('modal-restbetaling').value = '';
		
		// Clear checkboxes
		document.getElementById('ontbijt').checked = false;
		document.getElementById('linnen').checked = false;
		document.getElementById('handdoeken').checked = false;
		document.getElementById('parkeren').checked = false;
		
		// Clear textareas
		const publicTextarea = document.querySelector('#opmerkingen-tab textarea:first-of-type');
		const internTextarea = document.querySelector('#opmerkingen-tab textarea:last-of-type');
		if (publicTextarea) publicTextarea.value = '';
		if (internTextarea) internTextarea.value = '';
	}
	
	// Accommodatie functions
	let allAccommodaties = [];
	
	async function loadAccommodatiesForSelector() {
		try {
			const response = await fetch('/api/accommodaties');
			if (!response.ok) throw new Error('Failed to fetch accommodaties');
			
			const result = await response.json();
			allAccommodaties = result.data || [];
			populateKamerSelector();
		} catch (error) {
			console.error('Error loading accommodaties:', error);
		}
	}
	
	function populateKamerSelector() {
		const kamerSelect = document.getElementById('modal-kamer');
		if (!kamerSelect) return;
		
		// Clear existing options except the first one
		kamerSelect.innerHTML = '<option value="">Selecteer een accommodatie...</option>';
		
		// Add accommodaties as options
		allAccommodaties.forEach(accommodatie => {
			const option = document.createElement('option');
			option.value = accommodatie.name;
			option.textContent = `${accommodatie.name} (max ${accommodatie.max_guests} gasten)`;
			kamerSelect.appendChild(option);
		});
	}
	
	async function loadGastenForSelector() {
		try {
			const response = await fetch('/api/gasten');
			if (!response.ok) throw new Error('Failed to fetch gasten');
			
			allGasten = await response.json();
			console.log('Loaded gasten:', allGasten);
			populateGastSelector();
		} catch (error) {
			console.error('Error loading gasten:', error);
			allGasten = []; // Fallback to empty array
		}
	}
	
	function populateGastSelector() {
		// This function is now used for search results - but only show when search is active
		// Don't automatically show results when loading gasten
		console.log('Gasten loaded, but not showing results automatically');
	}
	
	function activateGastSearch() {
		// Activate search mode - show confirm/cancel buttons and change placeholder
		const searchInput = document.getElementById('gast-search-input');
		const confirmBtn = document.getElementById('confirm-gast-btn');
		const cancelBtn = document.getElementById('cancel-gast-btn');
		
		if (searchInput) {
			searchInput.placeholder = 'Type naam of email...';
			searchInput.readOnly = false;
			searchInput.setAttribute('oninput', 'searchGasten()');
			searchInput.removeAttribute('onclick'); // Remove onclick to prevent re-activation
			// Focus again to allow typing
			setTimeout(() => searchInput.focus(), 50);
		}
		
		if (confirmBtn) confirmBtn.classList.remove('hidden');
		if (cancelBtn) cancelBtn.classList.remove('hidden');
	}

	function searchGasten() {
		const searchTerm = document.getElementById('gast-search-input').value.toLowerCase();
		
		if (searchTerm.length < 2) {
			const searchResults = document.getElementById('gast-search-results');
			const confirmBtn = document.getElementById('confirm-gast-btn');
			const cancelBtn = document.getElementById('cancel-gast-btn');
			
			if (searchResults) searchResults.classList.add('hidden');
			if (confirmBtn) confirmBtn.classList.add('hidden');
			if (cancelBtn) cancelBtn.classList.add('hidden');
			return;
		}
		
		// Show confirm/cancel buttons when actively searching
		const confirmBtn = document.getElementById('confirm-gast-btn');
		const cancelBtn = document.getElementById('cancel-gast-btn');
		
		if (confirmBtn) confirmBtn.classList.remove('hidden');
		if (cancelBtn) cancelBtn.classList.remove('hidden');
		
		const filteredGasten = allGasten.filter(gast => 
			gast.name.toLowerCase().includes(searchTerm) || 
			gast.email.toLowerCase().includes(searchTerm) ||
			(gast.telefoon && gast.telefoon.includes(searchTerm))
		);
		
		displayGastResults(filteredGasten);
	}
	
	function showGastResults() {
		// Only show results if search is active (confirm/cancel buttons are visible)
		const confirmBtn = document.getElementById('confirm-gast-btn');
		if (confirmBtn && !confirmBtn.classList.contains('hidden')) {
			// Show all gasten when focusing on search input
			displayGastResults(allGasten.slice(0, 10)); // Limit to first 10 for performance
		}
	}
	
	function displayGastResults(gasten) {
		const resultsContainer = document.getElementById('gast-search-results');
		
		// Only display results if search is active
		const confirmBtn = document.getElementById('confirm-gast-btn');
		if (!confirmBtn || confirmBtn.classList.contains('hidden')) {
			return; // Don't show results if search is not active
		}
		
		if (gasten.length === 0) {
			resultsContainer.innerHTML = '<div class="p-3 text-gray-500 text-sm">Geen gasten gevonden</div>';
		} else {
			resultsContainer.innerHTML = gasten.map(gast => `
				<div class="p-3 hover:bg-gray-100 dark:hover:bg-gray-600 cursor-pointer border-b border-gray-200 dark:border-gray-600 last:border-b-0" 
					 data-gast-id="${gast.id}" onclick="selectGastFromSearchByElement(this)">
					<div class="flex items-center justify-between">
						<div>
							<div class="font-medium text-gray-900 dark:text-white">${gast.name}</div>
							<div class="text-sm text-gray-500 dark:text-gray-400">${gast.email}</div>
						</div>
						<div class="text-xs text-gray-400">
							${gast.aantal_bezoeken || 0} bezoeken
						</div>
					</div>
				</div>
			`).join('');
		}
		
		resultsContainer.classList.remove('hidden');
	}
	
	function toggleGastSelector() {
		const selector = document.getElementById('gast-selector');
		const currentInfo = document.getElementById('current-gast-info');
		
		if (selector.classList.contains('hidden')) {
			selector.classList.remove('hidden');
			currentInfo.classList.add('hidden');
		} else {
			selector.classList.add('hidden');
			currentInfo.classList.remove('hidden');
		}
	}
	
	function selectGast() {
		// Legacy function - kept for compatibility
	}
	
	function selectGastFromSearchByElement(element) {
		const gastId = element.getAttribute('data-gast-id');
		selectGastFromSearch(gastId);
	}
	
	function selectGastFromSearch(gastId) {
		selectedGastData = allGasten.find(gast => gast.id == gastId);
		
		if (selectedGastData) {
			// Update search input to show selected gast
			document.getElementById('gast-search-input').value = `${selectedGastData.name} (${selectedGastData.email})`;
			
			// Hide results
			document.getElementById('gast-search-results').classList.add('hidden');
			
			// Show the gast info section with readonly fields
			document.getElementById('current-gast-info').classList.remove('hidden');
			
			// Fill and make readonly
			const gastNaamField = document.getElementById('modal-gast-naam');
			const gastEmailField = document.getElementById('modal-gast-email');
			const gastTelefoonField = document.getElementById('modal-gast-telefoon');
			
			gastNaamField.value = selectedGastData.name;
			gastEmailField.value = selectedGastData.email;
			gastTelefoonField.value = selectedGastData.telefoon || '';
			
			// Make readonly
			gastNaamField.readOnly = true;
			gastEmailField.readOnly = true;
			gastTelefoonField.readOnly = true;
			
			// Change styling to show they're readonly
			gastNaamField.classList.remove('bg-white');
			gastEmailField.classList.remove('bg-white');
			gastTelefoonField.classList.remove('bg-white');
			
			gastNaamField.classList.add('bg-gray-100');
			gastEmailField.classList.add('bg-gray-100');
			gastTelefoonField.classList.add('bg-gray-100');
			
			// Enable confirm button
			document.getElementById('confirm-gast-btn').disabled = false;
			document.getElementById('confirm-gast-btn').classList.remove('opacity-50');
		}
	}
	
	function confirmGastChange() {
		if (selectedGastData) {
			// Update the hidden gast ID field
			document.getElementById('modal-gast-id').value = selectedGastData.id;
			
			showNotification('Gast gewijzigd naar ' + selectedGastData.name, 'success');
		}
		
		// Hide selector (gast info is already shown)
		document.getElementById('gast-selector').classList.add('hidden');
	}
	
	function cancelGastChange() {
		// Reset search to inactive state
		const searchInput = document.getElementById('gast-search-input');
		const searchResults = document.getElementById('gast-search-results');
		const confirmBtn = document.getElementById('confirm-gast-btn');
		const cancelBtn = document.getElementById('cancel-gast-btn');
		
		if (searchInput) {
			searchInput.value = '';
			searchInput.placeholder = 'Klik hier om te zoeken naar bestaande gast...';
			searchInput.readOnly = true;
			searchInput.removeAttribute('oninput');
			searchInput.setAttribute('onclick', 'activateGastSearch()'); // Restore onclick handler
		}
		
		if (searchResults) searchResults.classList.add('hidden');
		if (confirmBtn) {
			confirmBtn.classList.add('hidden');
			confirmBtn.disabled = true;
			confirmBtn.classList.add('opacity-50');
		}
		if (cancelBtn) cancelBtn.classList.add('hidden');
		
		selectedGastData = null;
		
		// For existing reserveringen, hide selector and show current info
		if (window.currentReserveringId) {
			document.getElementById('gast-selector').classList.add('hidden');
			document.getElementById('current-gast-info').classList.remove('hidden');
		}
	}
	
	function showNewGastForm() {
		// Hide the gast selector completely
		document.getElementById('gast-selector').classList.add('hidden');
		
		// Show the gast info section with editable fields
		document.getElementById('current-gast-info').classList.remove('hidden');
		
		// Enable the form fields for manual entry
		const gastNaamField = document.getElementById('modal-gast-naam');
		const gastEmailField = document.getElementById('modal-gast-email');
		const gastTelefoonField = document.getElementById('modal-gast-telefoon');
		
		gastNaamField.disabled = false;
		gastEmailField.disabled = false;
		gastTelefoonField.disabled = false;
		
		gastNaamField.readOnly = false;
		gastEmailField.readOnly = false;
		gastTelefoonField.readOnly = false;
		
		// Change styling to show they're editable
		gastNaamField.classList.remove('bg-gray-100');
		gastEmailField.classList.remove('bg-gray-100');
		gastTelefoonField.classList.remove('bg-gray-100');
		
		gastNaamField.classList.add('bg-white');
		gastEmailField.classList.add('bg-white');
		gastTelefoonField.classList.add('bg-white');
		
		// Clear the fields
		gastNaamField.value = '';
		gastEmailField.value = '';
		gastTelefoonField.value = '';
		
		// Focus on the name field
		gastNaamField.focus();
		
		// Clear selected gast data
		selectedGastData = null;
		
		// Show "Bestaande gast" button where "Andere gast" normally is
		showBestaandeGastButton();
		
		showNotification('Vul de gastgegevens handmatig in', 'info');
	}
	
	function showBestaandeGastButton() {
		// Find the "Andere gast" button and change it to "Bestaande gast"
		const andereGastBtn = document.querySelector('button[onclick="toggleGastSelector()"]');
		if (andereGastBtn) {
			andereGastBtn.textContent = 'Bestaande gast';
			andereGastBtn.setAttribute('onclick', 'showBestaandeGastSelector()');
		}
	}
	
	function showBestaandeGastSelector() {
		// Hide current gast info
		document.getElementById('current-gast-info').classList.add('hidden');
		
		// Show gast selector
		document.getElementById('gast-selector').classList.remove('hidden');
		
		// Reset the button back to "Andere gast"
		const bestaandeGastBtn = document.querySelector('button[onclick="showBestaandeGastSelector()"]');
		if (bestaandeGastBtn) {
			bestaandeGastBtn.textContent = 'Andere gast';
			bestaandeGastBtn.setAttribute('onclick', 'toggleGastSelector()');
		}
		
		// Clear search and hide buttons initially
		document.getElementById('gast-search-input').value = '';
		document.getElementById('gast-search-results').classList.add('hidden');
		document.getElementById('confirm-gast-btn').classList.add('hidden');
		document.getElementById('cancel-gast-btn').classList.add('hidden');
		
		selectedGastData = null;
	}
	
	// Hide search results when clicking outside
	document.addEventListener('click', function(event) {
		const searchContainer = document.getElementById('gast-selector');
		const searchResults = document.getElementById('gast-search-results');
		
		if (!searchContainer.contains(event.target)) {
			searchResults.classList.add('hidden');
		}
	});

	async function saveReservering() {
		try {
			// Collect form data
			const formData = {
				gast_id: document.getElementById('modal-gast-id').value,
				gast_naam: document.getElementById('modal-gast-naam').value,
				gast_email: document.getElementById('modal-gast-email').value,
				gast_telefoon: document.getElementById('modal-gast-telefoon').value,
				check_in: convertDateFormat(document.getElementById('modal-check-in').value),
				check_out: convertDateFormat(document.getElementById('modal-check-out').value),
				kamer: document.getElementById('modal-kamer').value,
				aantal_gasten: parseInt(document.getElementById('modal-aantal-gasten').value) || 1,
				prijs_per_nacht: parseFloat(document.getElementById('modal-prijs-per-nacht').value) || 0,
				totaal_prijs: parseFloat(document.getElementById('modal-totaal-prijs').value) || 0,
				betaalstatus: document.getElementById('modal-betaalstatus').value,
				reservering_status: document.getElementById('modal-status').value,
				ontbijt: document.getElementById('ontbijt').checked ? 1 : 0,
				linnen: document.getElementById('linnen').checked ? 1 : 0,
				handdoeken: document.getElementById('handdoeken').checked ? 1 : 0,
				parkeren: document.getElementById('parkeren').checked ? 1 : 0,
				korting: parseFloat(document.getElementById('modal-korting').value) || 0,
				borg: parseFloat(document.getElementById('modal-borg').value) || 50,
				aanbetaling: parseFloat(document.getElementById('modal-aanbetaling').value) || 0,
				restbetaling: parseFloat(document.getElementById('modal-restbetaling').value) || 0,
				opmerkingen_publiek: document.querySelector('#opmerkingen-tab textarea:first-of-type').value,
				opmerkingen_intern: document.querySelector('#opmerkingen-tab textarea:last-of-type').value
			};
			
			console.log('Saving reservering with data:', formData);
			
			// Validate required fields
			if (!formData.gast_naam || !formData.gast_email || !formData.check_in || !formData.check_out || !formData.kamer) {
				showNotification('Vul alle verplichte velden in (Gast naam, email, check-in, check-out, kamer)', 'error');
				return;
			}
			
			// Determine if this is a new reservering or update
			const isNewReservering = !window.currentReserveringId;
			const method = isNewReservering ? 'POST' : 'PUT';
			
			// Add ID only for existing reserveringen
			if (!isNewReservering) {
				formData.id = window.currentReserveringId;
			}
			
			const response = await fetch('/api/reserveringen', {
				method: method,
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify(formData)
			});
			
			if (!response.ok) {
				throw new Error('Failed to save reservering');
			}
			
			const result = await response.json();
			console.log('Reservering saved successfully:', result);
			
			const successMessage = isNewReservering ? 'Nieuwe reservering aangemaakt!' : 'Reservering bijgewerkt!';
			showNotification(successMessage, 'success');
			closeReserveringModal();
			
			// Reload the reserveringen table data
			await reloadReserveringenTable();
			
		} catch (error) {
			console.error('Error saving reservering:', error);
			showNotification('Fout bij het opslaan van de reservering', 'error');
		}
	}
	
	// Helper function to format date to Dutch format (dd-mm-yyyy)
	function formatDateToDutch(dateString) {
		if (!dateString) return '';
		try {
			const date = new Date(dateString);
			return date.toLocaleDateString('nl-NL', {
				day: '2-digit',
				month: '2-digit', 
				year: 'numeric'
			});
		} catch (error) {
			console.error('Error formatting date:', error);
			return dateString;
		}
	}

	async function reloadReserveringenTable() {
		try {
			console.log('Reloading reserveringen table...');
			
			// Fetch updated reserveringen data
			const response = await fetch('/api/reserveringen');
			if (!response.ok) {
				throw new Error('Failed to fetch reserveringen');
			}
			
			const reserveringen = await response.json();
			console.log('Loaded reserveringen:', reserveringen);
			
			// Update the table body
			const tbody = document.querySelector('table tbody');
			if (!tbody) {
				console.error('Table body not found');
				return;
			}
			
			// Generate new table rows - match original Astro template structure exactly
			tbody.innerHTML = reserveringen.map(reservering => `
				<tr class="hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer reservering-row" 
					data-reservering-id="${reservering.id}">
					<td class="w-4 p-4">
						<div class="flex items-center">
							<input id="checkbox-${reservering.id}" aria-describedby="checkbox-1" type="checkbox" 
								class="w-4 h-4 border-gray-300 rounded bg-gray-50 focus:ring-3 focus:ring-primary-300 dark:focus:ring-primary-600 dark:ring-offset-gray-800 dark:bg-gray-700 dark:border-gray-600">
							<label for="checkbox-${reservering.id}" class="sr-only">checkbox</label>
						</div>
					</td>
					<td class="p-4 text-sm font-normal text-gray-500 whitespace-nowrap dark:text-gray-400">
						<div class="text-base font-semibold text-gray-900 dark:text-white">
							<data value="gast_naam">${reservering.gast_naam}</data>
						</div>
						<div class="text-sm font-normal text-gray-500 dark:text-gray-400">
							<data value="kamer">${reservering.kamer}</data>
						</div>
					</td>
					<td class="p-4 text-base font-medium text-gray-900 whitespace-nowrap dark:text-white">
						<data value="check_in">${formatDateToDutch(reservering.check_in)}</data>
					</td>
					<td class="p-4 text-base font-medium text-gray-900 whitespace-nowrap dark:text-white">
						<data value="check_out">${formatDateToDutch(reservering.check_out)}</data>
					</td>
					<td class="p-4 text-base font-medium text-gray-900 whitespace-nowrap dark:text-white">
						<span class="px-2 py-1 text-xs font-medium rounded-full ${
							reservering.status === 'confirmed' ? 'bg-green-100 text-green-800' :
							reservering.status === 'pending' ? 'bg-yellow-100 text-yellow-800' :
							reservering.status === 'checked_in' ? 'bg-blue-100 text-blue-800' :
							reservering.status === 'checked_out' ? 'bg-gray-100 text-gray-800' :
							'bg-red-100 text-red-800'
						}">
							${reservering.status === 'confirmed' ? 'Bevestigd' :
							  reservering.status === 'pending' ? 'Wachtlijst' :
							  reservering.status === 'checked_in' ? 'Check-in' :
							  reservering.status === 'checked_out' ? 'Check-out' :
							  reservering.status === 'cancelled' ? 'Geannuleerd' :
							  reservering.status === 'no_show' ? 'No-show' :
							  reservering.status || 'Onbekend'}
						</span>
					</td>
					<td class="p-4 text-base font-medium text-gray-900 whitespace-nowrap dark:text-white">
						<data value="totaal_prijs">${reservering.totaal_prijs}</data>
					</td>
					<td class="p-4 text-base font-medium text-gray-900 whitespace-nowrap dark:text-white">
						<span class="px-2 py-1 text-xs font-medium rounded-full ${
							reservering.betaalstatus === 'paid' ? 'bg-green-100 text-green-800' :
							reservering.betaalstatus === 'partial' ? 'bg-yellow-100 text-yellow-800' :
							reservering.betaalstatus === 'refunded' ? 'bg-gray-100 text-gray-800' :
							'bg-red-100 text-red-800'
						}">
							${reservering.betaalstatus === 'paid' ? 'Volledig Betaald' :
							  reservering.betaalstatus === 'partial' ? 'Deels Betaald' :
							  reservering.betaalstatus === 'pending' ? 'Niet Betaald' :
							  reservering.betaalstatus === 'refunded' ? 'Terugbetaald' :
							  reservering.betaalstatus || 'Onbekend'}
						</span>
					</td>
				</tr>
			`).join('');
			
			// Re-attach event listeners to new rows
			attachRowEventListeners();
			
			console.log('Table reloaded successfully');
			
		} catch (error) {
			console.error('Error reloading table:', error);
		}
	}
	
	function attachRowEventListeners() {
		// Re-attach click event listeners to table rows
		document.querySelectorAll('table tbody tr[data-reservering-id]').forEach(row => {
			row.addEventListener('click', function() {
				const reserveringId = this.getAttribute('data-reservering-id');
				if (reserveringId) {
					openReserveringModal(reserveringId);
				}
			});
		});
	}
	
	// Make functions globally available
	window.openReserveringModal = openReserveringModal;
	window.openNieuweReserveringModal = openNieuweReserveringModal;
	window.closeReserveringModal = closeReserveringModal;
	window.switchTab = switchTab;
	window.saveReservering = saveReservering;
	window.toggleGastSelector = toggleGastSelector;
	window.selectGast = selectGast;
	window.selectGastFromSearch = selectGastFromSearch;
	window.selectGastFromSearchByElement = selectGastFromSearchByElement;
	window.searchGasten = searchGasten;
	window.activateGastSearch = activateGastSearch;
	window.showGastResults = showGastResults;
	window.confirmGastChange = confirmGastChange;
	window.cancelGastChange = cancelGastChange;
	window.showBestaandeGastSelector = showBestaandeGastSelector;
	window.showBestaandeGastButton = showBestaandeGastButton;
	window.showNewGastForm = showNewGastForm;
	
	// Format existing dates to Dutch format on page load
	function formatExistingDates() {
		document.querySelectorAll('data[value="check_in"], data[value="check_out"]').forEach(element => {
			const originalDate = element.textContent.trim();
			if (originalDate) {
				element.textContent = formatDateToDutch(originalDate);
			}
		});
	}

	// Initialize event listeners when page loads
	document.addEventListener('DOMContentLoaded', function() {
		attachRowEventListeners();
		formatExistingDates();
	});
</script>

